{
  "name": "writerly-vscode-extension",
  "icon": "logo.png",
  "displayName": "Writerly",
  "description": "Writerly support for VS Code with file navigation - open images, documents, and files under cursor",
  "version": "0.0.105",
  "publisher": "TabbyNotes",
  "author": {
    "name": "Chaker Atallah"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "repository": {
    "url": "https://github.com/vistuleB/writerly-vscode-extension.git"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "writerly",
    "file navigation",
    "open file",
    "cursor",
    "image viewer",
    "document opener",
    "path resolver"
  ],
  "activationEvents": [],
  "main": "./out/extension",
  "contributes": {
    "languages": [
      {
        "id": "writerly",
        "aliases": [
          "Writerly",
          "writerly",
          "wly"
        ],
        "extensions": [
          ".wly"
        ],
        "configuration": "./writerly.configuration.json"
      }
    ],
    "configuration": {
      "title": "Writerly",
      "properties": {
        "writerly.enableUnusedHandleWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable warnings for unused handle definitions."
        },
        "writerly.enableMissingFileWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable warnings for missing local files in path-bearing Writerly attributes."
        },
        "writerly.templateFilesDirectory": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Workspace-relative directory containing Writerly template files used by 'Create File From Template'. Should be set at the workspace level."
        }
      }
    },
    "grammars": [
      {
        "language": "writerly",
        "scopeName": "source.writerly",
        "path": "./syntaxes/writerly.json"
      }
    ],
    "commands": [
      {
        "command": "writerly.openUnderCursorWithDefault",
        "title": "Open File Under Cursor With Default",
        "category": "Writerly"
      },
      {
        "command": "writerly.openUnderCursorWithVSCode",
        "title": "Open File Under Cursor With VSCode",
        "category": "Writerly"
      },
      {
        "command": "writerly.openUnderCursorAsImageWithVSCode",
        "title": "Open File Under Cursor As Image With VSCode",
        "category": "Writerly"
      },
      {
        "command": "writerly.openFileWithDefault",
        "title": "Open Current File with Default",
        "category": "Writerly"
      },
      {
        "command": "writerly.restart",
        "title": "Restart Extension",
        "category": "Writerly"
      },
      {
        "command": "writerly.renameFileUnderCursor",
        "title": "Rename File Under Cursor",
        "category": "Writerly"
      },
      {
        "command": "writerly.moveFileUnderCursor",
        "title": "Move File Under Cursor",
        "category": "Writerly"
      },
      {
        "command": "writerly.createFileUnderCursorFromTemplate",
        "title": "Create File From Template",
        "category": "Writerly"
      },
      {
        "command": "writerly.inspectDocumentTree",
        "title": "Inspect Document Tree",
        "category": "Writerly"
      },
      {
        "command": "writerly.toggleDocumentTreeInspector",
        "title": "Toggle Document Tree",
        "category": "Writerly"
      },
      {
        "command": "writerly.goToHandleUsage",
        "title": "Go to Handle Usage",
        "category": "Writerly"
      }
    ],
    "keybindings": [
      {
        "command": "writerly.openUnderCursorWithDefault",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "editorTextFocus && editorLangId == writerly"
      },
      {
        "command": "writerly.navigateDocumentTreeUp",
        "key": "up",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.navigateDocumentTreeDown",
        "key": "down",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.navigateDocumentTreeFirst",
        "key": "ctrl+up",
        "mac": "cmd+up",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.navigateDocumentTreeLast",
        "key": "ctrl+down",
        "mac": "cmd+down",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.navigateDocumentTreeParent",
        "key": "left",
        "when": "writerlyDocumentTreeActive"
      },
      {
        "command": "writerly.navigateDocumentTreeChild",
        "key": "right",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.navigateDocumentTreePreviousSibling",
        "key": "alt+up",
        "mac": "alt+up",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.navigateDocumentTreePreviousSibling",
        "key": "alt+left",
        "mac": "alt+left",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.navigateDocumentTreeNextSibling",
        "key": "alt+down",
        "mac": "alt+down",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.navigateDocumentTreeNextSibling",
        "key": "alt+right",
        "mac": "alt+right",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.focusDocumentTreeFile",
        "key": "enter",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.focusDocumentTreeFile",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      },
      {
        "command": "writerly.focusDocumentTreeFileAndClose",
        "key": "shift+enter",
        "when": "editorTextFocus && resourceScheme == 'writerly-document-tree'"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "writerly.openFileWithDefault"
        }
      ],
      "editor/context": [
        {
          "command": "writerly.openUnderCursorWithDefault",
          "when": "editorLangId == writerly",
          "group": "navigation@1"
        },
        {
          "command": "writerly.openFileWithDefault",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "writerly-explorer",
          "title": "Writerly Explorer",
          "icon": "logo_outline.svg"
        }
      ]
    },
    "views": {
      "writerly-explorer": [
        {
          "id": "writerlyFiles",
          "name": "Writerly Files in Workspace"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "compile-watch": "onchange 'src/**/*.ts' -- npm run compile"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "glob": "^10.3.10",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "6.0.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.106.1",
    "@vscode/vsce": "^2.22.0",
    "onchange": "^7.1.0",
    "typescript": "^5.3.3"
  }
}
